# ── Database (required) ───────────────────────────────────────────────────────
# PostgreSQL connection string. Use the direct (non-pooled) connection for
# migrations (port 5432) and the pooled connection (port 6543) for the app.
# Examples:
#   Local:   postgresql://donebond:donebond@localhost:5432/donebond
#   Supabase: postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://donebond:donebond@localhost:5432/donebond
DATABASE_SSL=require           # "require" (default) or "disable" (loopback only)
DATABASE_MAX_CONNECTIONS=10    # 1..50
DATABASE_IDLE_TIMEOUT_SECONDS=20
DATABASE_CONNECT_TIMEOUT_SECONDS=10
# DATABASE_CA_CERT=            # optional TLS CA certificate string

# ── Public app origin (required) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ── Authentication secrets (required) ────────────────────────────────────────
# Generate with:  node -e "process.stdout.write(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=
CLI_TOKEN_SECRET=

# ── Monad chain (required for on-chain features) ─────────────────────────────
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.testnet.monad.xyz
MONAD_RPC_URL=https://rpc.testnet.monad.xyz      # server-side (falls back to public)
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadscan.com
NEXT_PUBLIC_DONEBOND_CONTRACT_ADDRESS=           # deployed contract address
DONEBOND_DEPLOYMENT_BLOCK=                       # block the contract was deployed at
DONEBOND_CONFIRMATIONS=2                         # 1..100

# ── Verifier signing key (required for receipt attestations) ──────────────────
# A 0x-prefixed 32-byte private key whose address must match the deployed
# DoneBondRegistry's immutable verifier. The server uses it only to sign EIP-712
# PassingReceipt attestations; it never signs or submits a transaction itself.
# Generate with:  node -e "process.stdout.write('0x'+require('crypto').randomBytes(32).toString('hex'))"
VERIFIER_PRIVATE_KEY=

# ── Optional test / CI overrides ─────────────────────────────────────────────
# TEST_DATABASE_URL=            # separate database for integration tests
# DONEBOND_ALLOW_DATABASE_RESET=  # set to "test-only-confirmed" to allow schema reset
# DONEBOND_ALLOW_REMOTE_TEST_DATABASE=  # set to "test-only-confirmed" for remote test DBs
# MONAD_EXPLORER_API_URL=      # explorer API for automatic chain metadata
# MONAD_EXPLORER_API_KEY=
