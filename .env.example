# Server-only database connection. Replace locally; never commit the real value.
DATABASE_URL=postgresql://donebond:donebond@localhost:5432/donebond

# Public application origin used to construct receipt links.
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Monad configuration must be reconfirmed against official documentation before deployment.
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://rpc.testnet.monad.xyz
MONAD_RPC_URL=https://rpc.testnet.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadscan.com
NEXT_PUBLIC_DONEBOND_CONTRACT_ADDRESS=
DONEBOND_DEPLOYMENT_BLOCK=
DONEBOND_CONFIRMATIONS=2
MONAD_EXPLORER_API_URL=
MONAD_EXPLORER_API_KEY=

# Base64url-encode at least 32 random bytes. Used only to key opaque session/CSRF digests.
AUTH_SECRET=

# Independent base64url-encoded 32-byte key for domain-separated CLI-token and retry-stable public-ID HMACs.
CLI_TOKEN_SECRET=

# ADR-004 verifier signing key: a 0x-prefixed 32-byte private key whose address must match
# the deployed DoneBondRegistry's immutable `verifier`. The server uses it only to sign an
# EIP-712 PassingReceipt attestation (a data field the assignee's own wallet later submits);
# it never signs or submits a transaction itself and never custodies task rewards. This must
# be a securely provisioned secret from a platform secret store in any real deployment, never
# a value committed to this file or any other tracked file. Generate a fresh throwaway key for
# local development/testing only, e.g. `cast wallet new` or an equivalent offline generator.
VERIFIER_PRIVATE_KEY=
