{
  "name": "donebond",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-neutral proof-of-done and outcome settlement",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "24.14.0",
    "pnpm": "11.6.0"
  },
  "scripts": {
    "boundaries": "node scripts/check-workspace-boundaries.mjs",
    "audit:prod": "pnpm audit --prod --audit-level=critical",
    "build": "turbo run build --filter=!@donebond/contracts",
    "db:migrate": "node --experimental-strip-types packages/db/src/migrate.ts",
    "donebond": "pnpm --filter @donebond/cli build && node apps/cli/dist/index.js",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && pnpm boundaries",
    "secrets:scan": "node scripts/scan-secrets.mjs --history",
    "test": "node --test scripts/check-workspace-boundaries.test.mjs && turbo run test --filter=!@donebond/contracts",
    "up": "bash scripts/up.sh && pnpm dev",
    "test:contracts": "turbo run test:contracts --filter=@donebond/contracts",
    "test:e2e": "turbo run test:e2e --filter=@donebond/e2e",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:contracts && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@types/node": "26.1.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "turbo": "2.10.5",
    "typescript": "5.9.3"
  }
}
