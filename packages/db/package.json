{
  "name": "@donebond/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node --enable-source-maps dist/migrate.js",
    "test": "tsc -p ../shared/tsconfig.json && pnpm build && node --test test/*.test.mjs",
    "test:integration": "pnpm build && node --test test/postgres.integration.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@donebond/shared": "workspace:*",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "typescript": "catalog:"
  }
}
