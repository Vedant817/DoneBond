{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://donebond.dev/schemas/evidence-bundle-v1.json",
  "title": "DoneBond Evidence Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "task",
    "policy",
    "git",
    "checks",
    "result",
    "tool",
    "redactions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicId", "taskHash"],
      "properties": {
        "publicId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "taskHash": { "$ref": "#/$defs/bytes32" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyHash", "sourcePath"],
      "properties": {
        "policyHash": { "$ref": "#/$defs/bytes32" },
        "sourcePath": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objectId",
        "derivedCommitHash",
        "treeId",
        "branch",
        "remote",
        "clean",
        "changedFiles"
      ],
      "properties": {
        "objectId": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
        "derivedCommitHash": { "$ref": "#/$defs/bytes32" },
        "treeId": { "type": "string", "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" },
        "branch": { "type": "string", "minLength": 1, "maxLength": 255 },
        "remote": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^github\\.com/[a-z0-9_.-]+/[a-z0-9_.-]+$"
        },
        "clean": { "type": "boolean" },
        "changedFiles": {
          "type": "array",
          "maxItems": 5000,
          "items": { "type": "string", "maxLength": 1024 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "clean": { "const": true } } },
          "then": { "properties": { "changedFiles": { "maxItems": 0 } } }
        }
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "contains": {
        "type": "object",
        "required": ["required"],
        "properties": { "required": { "const": true } }
      },
      "items": { "$ref": "#/$defs/check" }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passing", "requiredPassed", "requiredTotal", "failureCodes"],
      "properties": {
        "passing": { "type": "boolean" },
        "requiredPassed": { "type": "integer", "minimum": 0 },
        "requiredTotal": { "type": "integer", "minimum": 0 },
        "failureCodes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 128 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "passing": { "const": true } } },
          "then": { "properties": { "failureCodes": { "maxItems": 0 } } },
          "else": { "properties": { "failureCodes": { "minItems": 1 } } }
        }
      ]
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "platform", "nodeVersion"],
      "properties": {
        "name": { "const": "donebond-cli" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "platform": { "type": "string", "minLength": 1, "maxLength": 128 },
        "nodeVersion": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "redactions": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  },
  "$defs": {
    "bytes32": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "label",
        "required",
        "status",
        "startedAt",
        "durationMs",
        "exitCode",
        "stdout",
        "stderr"
      ],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-zA-Z0-9._-]{1,64}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 128 },
        "required": { "type": "boolean" },
        "status": {
          "enum": ["passed", "failed", "timed_out", "skipped", "error"]
        },
        "startedAt": { "type": "string", "format": "date-time" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "exitCode": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"], "maxLength": 32 },
        "stdout": { "$ref": "#/$defs/output" },
        "stderr": { "$ref": "#/$defs/output" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "passed" } } },
          "then": {
            "properties": { "exitCode": { "const": 0 }, "signal": { "type": "null" } }
          }
        },
        {
          "if": { "properties": { "status": { "enum": ["timed_out", "error", "skipped"] } } },
          "then": { "properties": { "exitCode": { "type": "null" } } }
        }
      ]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preview", "digest", "originalBytes", "truncated"],
      "properties": {
        "preview": { "type": "string", "maxLength": 262144 },
        "digest": { "$ref": "#/$defs/digest" },
        "originalBytes": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      }
    }
  }
}
