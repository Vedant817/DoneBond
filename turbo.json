{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["pnpm-lock.yaml", "packages/config/**"],
  "globalEnv": ["CI", "NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test:contracts": {
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["@donebond/web#build"],
      "outputs": ["../../playwright-report/**", "../../test-results/**"]
    }
  }
}
